{
  "tables": {
    "users": {
      "fields": {
        "clerkId": "string — Clerk user ID (subject)",
        "email": "string",
        "name": "string (optional)",
        "imageUrl": "string (optional)",
        "createdAt": "number — Unix timestamp ms"
      },
      "indexes": ["by_clerk_id", "by_email"]
    },
    "notes": {
      "fields": {
        "ownerId": "Id<users>",
        "title": "string",
        "content": "string — markdown source",
        "contentText": "string — plain text mirror for search",
        "tags": "string[]",
        "category": "string (optional)",
        "isArchived": "boolean",
        "isPublic": "boolean",
        "shareId": "string (optional) — 14-char random ID",
        "wordCount": "number",
        "titleIsUserSet": "boolean — prevents AI overwriting user titles",
        "aiSummary": "string (optional)",
        "aiActionItems": "string[] (optional)",
        "aiSuggestedTitle": "string (optional)",
        "lastTitleHash": "string (optional) — FNV hash for drift detection",
        "lastSummaryHash": "string (optional)",
        "aiUsageCount": "number",
        "createdAt": "number",
        "updatedAt": "number"
      },
      "indexes": [
        "by_owner",
        "by_owner_archived_updated",
        "by_share_id",
        "search_content (full-text on contentText)",
        "search_title (full-text on title)"
      ]
    },
    "collaborators": {
      "fields": {
        "noteId": "Id<notes>",
        "userId": "Id<users>",
        "role": "'viewer' | 'editor'",
        "addedAt": "number"
      },
      "indexes": ["by_note", "by_user", "by_note_user"]
    },
    "shareRequests": {
      "fields": {
        "noteId": "Id<notes>",
        "ownerId": "Id<users>",
        "requesterId": "Id<users>",
        "status": "'pending' | 'approved' | 'denied'",
        "message": "string (optional)",
        "createdAt": "number",
        "respondedAt": "number (optional)"
      },
      "indexes": ["by_owner_status", "by_note", "by_requester_note"]
    },
    "activityLog": {
      "fields": {
        "userId": "Id<users>",
        "noteId": "Id<notes> (optional)",
        "action": "'created' | 'edited' | 'archived' | 'unarchived' | 'deleted' | 'shared' | 'unshared' | 'ai_summary' | 'ai_title' | 'ai_actions' | 'collaborator_added'",
        "createdAt": "number"
      },
      "indexes": ["by_user_date"]
    }
  }
}
